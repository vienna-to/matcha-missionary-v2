# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings → API). Restart `npm run dev` after changing.
#
# When these are present, the app uses Supabase + Realtime and prompts for a
# workspace code on first launch. When absent, it falls back to a localStorage
# adapter (no backend required, single-device).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
